{
  "name": "workcenter-ai-reviewer",
  "displayName": "WorkCenter — AI Code Review",
  "description": "AI-powered code review action for WorkCenter",
  "version": "0.1.0",
  "publisher": "mthalman",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "mthalman.workcenter"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "WorkCenter AI Code Review",
      "properties": {
        "workcenterAiReview.customPromptPath": {
          "type": "string",
          "default": "",
          "description": "Path to a custom code review prompt file. The file content replaces the built-in review instructions sent to the language model. The PR diff is always appended automatically. Supports absolute paths and paths relative to the workspace folder (single-root workspaces only)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
