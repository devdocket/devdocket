{
  "name": "devdocket-ado",
  "displayName": "DevDocket Azure DevOps",
  "description": "Azure DevOps provider for DevDocket — discovers assigned work items and PR reviews.",
  "version": "0.1.2",
  "publisher": "devdocket",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "SCM Providers",
    "Azure",
    "Other"
  ],
  "keywords": [
    "azure devops",
    "ado",
    "work items",
    "pull requests",
    "pipelines",
    "devdocket",
    "provider"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/devdocket/devdocket.git",
    "directory": "packages/ado"
  },
  "bugs": {
    "url": "https://github.com/devdocket/devdocket/issues"
  },
  "homepage": "https://github.com/devdocket/devdocket#readme",
  "galleryBanner": {
    "color": "#1F2937",
    "theme": "dark"
  },
  "preview": true,
  "extensionDependencies": [
    "devdocket.devdocket"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:devdocket.main"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": [
      {
        "title": "DevDocket Azure DevOps",
        "properties": {
          "devDocketAdo.projects": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "markdownDescription": "Azure DevOps organizations and projects to monitor. Each entry is either `<org>` (monitor the entire organization) or `<org>/<project>` (monitor a specific project). Supports multiple organizations.\n\nExample:\n\n```jsonc\n[\n  \"contoso\",\n  \"fabrikam/web-platform\"\n]\n```"
          },
          "devDocketAdo.refreshIntervalSeconds": {
            "type": "number",
            "default": 300,
            "description": "How often to refresh Azure DevOps data (in seconds). Minimum 60 seconds for periodic refresh; positive values below 60 are clamped to 60. Set to 0 or a negative value to disable periodic refresh."
          },
          "devDocketAdo.resurfaceOnNewVersion": {
            "type": "boolean",
            "default": true,
            "description": "Resurface PR reviews when new iterations are pushed."
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node ../../scripts/prepare-extension-license.mjs . && npm run build:prod",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@devdocket/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.92.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
