{
  "name": "workcenter-ado",
  "displayName": "WorkCenter — Azure DevOps",
  "description": "Azure DevOps provider for WorkCenter — discovers assigned work items and PR reviews.",
  "version": "0.1.0",
  "publisher": "mthalman",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "mthalman.workcenter"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "WorkCenter Azure DevOps",
      "properties": {
        "workcenterAdo.organization": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization name"
        },
        "workcenterAdo.projects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Azure DevOps projects to monitor"
        },
        "workcenterAdo.refreshIntervalSeconds": {
          "type": "number",
          "default": 300,
          "description": "How often to refresh Azure DevOps data (in seconds). Minimum 60 seconds. Values below 60 are clamped."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
