{
  "name": "workcenter",
  "displayName": "WorkCenter",
  "description": "A central hub for managing work across pull requests, issues, investigations, and follow-ups.",
  "version": "0.1.0",
  "publisher": "mthalman",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:workcenter.inbox",
    "onView:workcenter.queue",
    "onView:workcenter.focus",
    "onView:workcenter.sources",
    "onView:workcenter.history",
    "onCommand:workcenter.refresh",
    "onCommand:workcenter.dismissFromSources",
    "onCommand:workcenter.deleteItem"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "WorkCenter",
      "properties": {
        "workcenter.logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "description": "Log level for WorkCenter output channel"
        },
        "workcenter.showInboxNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when new items arrive in the Inbox"
        },
        "workcenter.viewLayout": {
          "type": "object",
          "default": {},
          "description": "Per-view layout mode. Keys are view names (inbox, queue, focus, history, sources) and values are 'flat' or 'tree'.",
          "properties": {
            "inbox": { "type": "string", "enum": ["flat", "tree"], "default": "tree" },
            "queue": { "type": "string", "enum": ["flat", "tree"], "default": "flat" },
            "focus": { "type": "string", "enum": ["flat", "tree"], "default": "flat" },
            "history": { "type": "string", "enum": ["flat", "tree"], "default": "flat" },
            "sources": { "type": "string", "enum": ["flat", "tree"], "default": "tree" }
          },
          "additionalProperties": false
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workcenter",
          "title": "WorkCenter",
          "icon": "resources/workcenter.svg"
        }
      ]
    },
    "views": {
      "workcenter": [
        {
          "id": "workcenter.inbox",
          "name": "Inbox"
        },
        {
          "id": "workcenter.queue",
          "name": "Queue"
        },
        {
          "id": "workcenter.focus",
          "name": "Focus"
        },
        {
          "id": "workcenter.history",
          "name": "History"
        },
        {
          "id": "workcenter.sources",
          "name": "Sources"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "workcenter.inbox",
        "contents": "No new items.\nProviders will discover items automatically."
      },
      {
        "view": "workcenter.queue",
        "contents": "No items in your queue.\nAccept items from Inbox or create one manually.\n[Create Work Item](command:workcenter.createItem)"
      },
      {
        "view": "workcenter.focus",
        "contents": "No active work.\nMove items from Queue to start working on them."
      },
      {
        "view": "workcenter.history",
        "contents": "Completed and archived items will appear here."
      },
      {
        "view": "workcenter.sources",
        "contents": "Discovered items from all providers will appear here."
      }
    ],
    "commands": [
      {
        "command": "workcenter.createItem",
        "title": "Create Work Item",
        "category": "WorkCenter",
        "icon": "$(add)"
      },
      {
        "command": "workcenter.acceptToFocus",
        "title": "Move to Focus",
        "category": "WorkCenter",
        "icon": "$(arrow-right)"
      },
      {
        "command": "workcenter.archiveItem",
        "title": "Archive",
        "category": "WorkCenter",
        "icon": "$(archive)"
      },
      {
        "command": "workcenter.completeItem",
        "title": "Complete",
        "category": "WorkCenter",
        "icon": "$(check)"
      },
      {
        "command": "workcenter.pauseItem",
        "title": "Pause",
        "category": "WorkCenter",
        "icon": "$(debug-pause)"
      },
      {
        "command": "workcenter.resumeItem",
        "title": "Resume",
        "category": "WorkCenter",
        "icon": "$(debug-continue)"
      },
      {
        "command": "workcenter.editItem",
        "title": "Edit Work Item",
        "category": "WorkCenter",
        "icon": "$(edit)"
      },
      {
        "command": "workcenter.openInBrowser",
        "title": "Open in Browser",
        "category": "WorkCenter",
        "icon": "$(link-external)"
      },
      {
        "command": "workcenter.runAction",
        "title": "Run Action…",
        "category": "WorkCenter",
        "icon": "$(play)"
      },
      {
        "command": "workcenter.moveUp",
        "title": "Move Up",
        "category": "WorkCenter",
        "icon": "$(arrow-up)"
      },
      {
        "command": "workcenter.moveDown",
        "title": "Move Down",
        "category": "WorkCenter",
        "icon": "$(arrow-down)"
      },
      {
        "command": "workcenter.focusMoveUp",
        "title": "Move Up",
        "category": "WorkCenter",
        "icon": "$(arrow-up)"
      },
      {
        "command": "workcenter.focusMoveDown",
        "title": "Move Down",
        "category": "WorkCenter",
        "icon": "$(arrow-down)"
      },
      {
        "command": "workcenter.acceptFromInbox",
        "title": "Accept to Queue",
        "category": "WorkCenter",
        "icon": "$(arrow-right)"
      },
      {
        "command": "workcenter.acceptToFocusFromInbox",
        "title": "Accept to Focus",
        "category": "WorkCenter",
        "icon": "$(rocket)"
      },
      {
        "command": "workcenter.dismissFromInbox",
        "title": "Dismiss",
        "category": "WorkCenter",
        "icon": "$(close)"
      },
      {
        "command": "workcenter.acceptFromSources",
        "title": "Accept to Queue",
        "category": "WorkCenter",
        "icon": "$(arrow-right)"
      },
      {
        "command": "workcenter.switchInboxToTree",
        "title": "Switch Inbox to Tree Layout",
        "category": "WorkCenter",
        "icon": "$(list-tree)"
      },
      {
        "command": "workcenter.switchInboxToFlat",
        "title": "Switch Inbox to Flat Layout",
        "category": "WorkCenter",
        "icon": "$(list-flat)"
      },
      {
        "command": "workcenter.switchQueueToTree",
        "title": "Switch Queue to Tree Layout",
        "category": "WorkCenter",
        "icon": "$(list-tree)"
      },
      {
        "command": "workcenter.switchQueueToFlat",
        "title": "Switch Queue to Flat Layout",
        "category": "WorkCenter",
        "icon": "$(list-flat)"
      },
      {
        "command": "workcenter.switchFocusToTree",
        "title": "Switch Focus to Tree Layout",
        "category": "WorkCenter",
        "icon": "$(list-tree)"
      },
      {
        "command": "workcenter.switchFocusToFlat",
        "title": "Switch Focus to Flat Layout",
        "category": "WorkCenter",
        "icon": "$(list-flat)"
      },
      {
        "command": "workcenter.switchHistoryToTree",
        "title": "Switch History to Tree Layout",
        "category": "WorkCenter",
        "icon": "$(list-tree)"
      },
      {
        "command": "workcenter.switchHistoryToFlat",
        "title": "Switch History to Flat Layout",
        "category": "WorkCenter",
        "icon": "$(list-flat)"
      },
      {
        "command": "workcenter.switchSourcesToTree",
        "title": "Switch Sources to Tree Layout",
        "category": "WorkCenter",
        "icon": "$(list-tree)"
      },
      {
        "command": "workcenter.switchSourcesToFlat",
        "title": "Switch Sources to Flat Layout",
        "category": "WorkCenter",
        "icon": "$(list-flat)"
      },
      {
        "command": "workcenter.toggleInboxLayout",
        "title": "Toggle Inbox Layout",
        "category": "WorkCenter"
      },
      {
        "command": "workcenter.toggleQueueLayout",
        "title": "Toggle Queue Layout",
        "category": "WorkCenter"
      },
      {
        "command": "workcenter.toggleFocusLayout",
        "title": "Toggle Focus Layout",
        "category": "WorkCenter"
      },
      {
        "command": "workcenter.toggleHistoryLayout",
        "title": "Toggle History Layout",
        "category": "WorkCenter"
      },
      {
        "command": "workcenter.toggleSourcesLayout",
        "title": "Toggle Sources Layout",
        "category": "WorkCenter"
      },
      {
        "command": "workcenter.dismissFromSources",
        "title": "Dismiss",
        "category": "WorkCenter",
        "icon": "$(close)"
      },
      {
        "command": "workcenter.deleteItem",
        "title": "Delete",
        "category": "WorkCenter",
        "icon": "$(trash)"
      },
      {
        "command": "workcenter.moveToQueue",
        "title": "Move to Queue",
        "category": "WorkCenter",
        "icon": "$(arrow-left)"
      },
      {
        "command": "workcenter.refresh",
        "title": "Refresh",
        "category": "WorkCenter",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "workcenter.createItem",
          "when": "view == workcenter.queue",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchInboxToTree",
          "when": "view == workcenter.inbox && workcenter.inboxLayout == flat",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchInboxToFlat",
          "when": "view == workcenter.inbox && workcenter.inboxLayout == tree",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchQueueToTree",
          "when": "view == workcenter.queue && workcenter.queueLayout == flat",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchQueueToFlat",
          "when": "view == workcenter.queue && workcenter.queueLayout == tree",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchFocusToTree",
          "when": "view == workcenter.focus && workcenter.focusLayout == flat",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchFocusToFlat",
          "when": "view == workcenter.focus && workcenter.focusLayout == tree",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchHistoryToTree",
          "when": "view == workcenter.history && workcenter.historyLayout == flat",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchHistoryToFlat",
          "when": "view == workcenter.history && workcenter.historyLayout == tree",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchSourcesToTree",
          "when": "view == workcenter.sources && workcenter.sourcesLayout == flat",
          "group": "navigation"
        },
        {
          "command": "workcenter.switchSourcesToFlat",
          "when": "view == workcenter.sources && workcenter.sourcesLayout == tree",
          "group": "navigation"
        },
        {
          "command": "workcenter.refresh",
          "when": "view == workcenter.inbox || view == workcenter.sources",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "workcenter.switchInboxToTree",
          "when": "workcenter.inboxLayout == flat"
        },
        {
          "command": "workcenter.switchInboxToFlat",
          "when": "workcenter.inboxLayout == tree"
        },
        {
          "command": "workcenter.switchQueueToTree",
          "when": "workcenter.queueLayout == flat"
        },
        {
          "command": "workcenter.switchQueueToFlat",
          "when": "workcenter.queueLayout == tree"
        },
        {
          "command": "workcenter.switchFocusToTree",
          "when": "workcenter.focusLayout == flat"
        },
        {
          "command": "workcenter.switchFocusToFlat",
          "when": "workcenter.focusLayout == tree"
        },
        {
          "command": "workcenter.switchHistoryToTree",
          "when": "workcenter.historyLayout == flat"
        },
        {
          "command": "workcenter.switchHistoryToFlat",
          "when": "workcenter.historyLayout == tree"
        },
        {
          "command": "workcenter.switchSourcesToTree",
          "when": "workcenter.sourcesLayout == flat"
        },
        {
          "command": "workcenter.switchSourcesToFlat",
          "when": "workcenter.sourcesLayout == tree"
        },
        {
          "command": "workcenter.toggleInboxLayout",
          "when": "false"
        },
        {
          "command": "workcenter.toggleQueueLayout",
          "when": "false"
        },
        {
          "command": "workcenter.toggleFocusLayout",
          "when": "false"
        },
        {
          "command": "workcenter.toggleHistoryLayout",
          "when": "false"
        },
        {
          "command": "workcenter.toggleSourcesLayout",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "workcenter.acceptToFocus",
          "when": "view == workcenter.queue && viewItem =~ /^queueItem/",
          "group": "inline"
        },
        {
          "command": "workcenter.archiveItem",
          "when": "view == workcenter.queue && viewItem =~ /^queueItem/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.deleteItem",
          "when": "view == workcenter.queue && viewItem =~ /^queueItem/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.completeItem",
          "when": "view == workcenter.focus && viewItem =~ /^(active|paused)/",
          "group": "inline"
        },
        {
          "command": "workcenter.archiveItem",
          "when": "view == workcenter.focus && viewItem =~ /^(active|paused)/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.pauseItem",
          "when": "view == workcenter.focus && viewItem =~ /^active/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.resumeItem",
          "when": "view == workcenter.focus && viewItem =~ /^paused/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.moveToQueue",
          "when": "view == workcenter.focus && viewItem =~ /^(active|paused)/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.moveUp",
          "when": "view == workcenter.queue && viewItem =~ /^queueItem/ && !listMultiSelection",
          "group": "3_reorder@1"
        },
        {
          "command": "workcenter.moveDown",
          "when": "view == workcenter.queue && viewItem =~ /^queueItem/ && !listMultiSelection",
          "group": "3_reorder@2"
        },
        {
          "command": "workcenter.focusMoveUp",
          "when": "view == workcenter.focus && viewItem =~ /^(active|paused)/ && !listMultiSelection",
          "group": "3_reorder@1"
        },
        {
          "command": "workcenter.focusMoveDown",
          "when": "view == workcenter.focus && viewItem =~ /^(active|paused)/ && !listMultiSelection",
          "group": "3_reorder@2"
        },
        {
          "command": "workcenter.openInBrowser",
          "when": "viewItem =~ /hasUrl/ && !listMultiSelection",
          "group": "2_links"
        },
        {
          "command": "workcenter.runAction",
          "when": "((view == workcenter.queue && viewItem =~ /^queueItem/) || (view == workcenter.focus && viewItem =~ /^(active|paused)/)) && !listMultiSelection",
          "group": "0_actions"
        },
        {
          "command": "workcenter.acceptFromInbox",
          "when": "view == workcenter.inbox && viewItem =~ /inboxItem/",
          "group": "inline"
        },
        {
          "command": "workcenter.acceptFromInbox",
          "when": "view == workcenter.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.dismissFromInbox",
          "when": "view == workcenter.inbox && viewItem =~ /inboxItem/",
          "group": "inline"
        },
        {
          "command": "workcenter.dismissFromInbox",
          "when": "view == workcenter.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.acceptToFocusFromInbox",
          "when": "view == workcenter.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.acceptFromSources",
          "when": "view == workcenter.sources && viewItem =~ /sourceItem/",
          "group": "inline"
        },
        {
          "command": "workcenter.dismissFromSources",
          "when": "view == workcenter.sources && viewItem =~ /sourceItem/",
          "group": "inline"
        },
        {
          "command": "workcenter.dismissFromSources",
          "when": "view == workcenter.sources && viewItem =~ /sourceItem/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.archiveItem",
          "when": "view == workcenter.history && viewItem =~ /historyItem\\.done/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.deleteItem",
          "when": "view == workcenter.history && viewItem =~ /^historyItem/",
          "group": "1_actions"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@workcenter/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
