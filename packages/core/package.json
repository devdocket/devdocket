{
  "name": "workcenter",
  "displayName": "WorkCenter",
  "description": "A central hub for managing work across pull requests, issues, investigations, and follow-ups.",
  "version": "0.1.0",
  "publisher": "mthalman",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:workcenter.inbox",
    "onView:workcenter.queue",
    "onView:workcenter.focus",
    "onView:workcenter.sources",
    "onView:workcenter.history"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "WorkCenter",
      "properties": {
        "workcenter.logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "description": "Log level for WorkCenter output channel"
        },
        "workcenter.showInboxNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when new items arrive in the Inbox"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workcenter",
          "title": "WorkCenter",
          "icon": "resources/workcenter.svg"
        }
      ]
    },
    "views": {
      "workcenter": [
        {
          "id": "workcenter.inbox",
          "name": "Inbox"
        },
        {
          "id": "workcenter.queue",
          "name": "Queue"
        },
        {
          "id": "workcenter.focus",
          "name": "Focus"
        },
        {
          "id": "workcenter.history",
          "name": "History"
        },
        {
          "id": "workcenter.sources",
          "name": "Sources"
        }
      ]
    },
    "commands": [
      {
        "command": "workcenter.createItem",
        "title": "Create Work Item",
        "category": "WorkCenter",
        "icon": "$(add)"
      },
      {
        "command": "workcenter.acceptToFocus",
        "title": "Move to Focus",
        "category": "WorkCenter",
        "icon": "$(arrow-right)"
      },
      {
        "command": "workcenter.archiveItem",
        "title": "Archive",
        "category": "WorkCenter",
        "icon": "$(archive)"
      },
      {
        "command": "workcenter.completeItem",
        "title": "Complete",
        "category": "WorkCenter",
        "icon": "$(check)"
      },
      {
        "command": "workcenter.pauseItem",
        "title": "Pause",
        "category": "WorkCenter",
        "icon": "$(debug-pause)"
      },
      {
        "command": "workcenter.resumeItem",
        "title": "Resume",
        "category": "WorkCenter",
        "icon": "$(debug-continue)"
      },
      {
        "command": "workcenter.editItem",
        "title": "Edit Work Item",
        "category": "WorkCenter",
        "icon": "$(edit)"
      },
      {
        "command": "workcenter.openInBrowser",
        "title": "Open in Browser",
        "category": "WorkCenter",
        "icon": "$(link-external)"
      },
      {
        "command": "workcenter.runAction",
        "title": "Run Action…",
        "category": "WorkCenter",
        "icon": "$(play)"
      },
      {
        "command": "workcenter.moveUp",
        "title": "Move Up",
        "category": "WorkCenter",
        "icon": "$(arrow-up)"
      },
      {
        "command": "workcenter.moveDown",
        "title": "Move Down",
        "category": "WorkCenter",
        "icon": "$(arrow-down)"
      },
      {
        "command": "workcenter.acceptFromInbox",
        "title": "Accept to Queue",
        "category": "WorkCenter",
        "icon": "$(arrow-right)"
      },
      {
        "command": "workcenter.dismissFromInbox",
        "title": "Dismiss",
        "category": "WorkCenter",
        "icon": "$(close)"
      },
      {
        "command": "workcenter.acceptFromSources",
        "title": "Accept to Queue",
        "category": "WorkCenter",
        "icon": "$(arrow-right)"
      },
      {
        "command": "workcenter.moveToQueue",
        "title": "Move to Queue",
        "category": "WorkCenter",
        "icon": "$(arrow-left)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "workcenter.createItem",
          "when": "view == workcenter.queue",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "workcenter.acceptToFocus",
          "when": "view == workcenter.queue",
          "group": "inline"
        },
        {
          "command": "workcenter.archiveItem",
          "when": "view == workcenter.queue",
          "group": "1_actions"
        },
        {
          "command": "workcenter.completeItem",
          "when": "view == workcenter.focus",
          "group": "inline"
        },
        {
          "command": "workcenter.pauseItem",
          "when": "view == workcenter.focus && viewItem =~ /^active/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.resumeItem",
          "when": "view == workcenter.focus && viewItem =~ /^paused/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.moveToQueue",
          "when": "view == workcenter.focus",
          "group": "1_actions"
        },
        {
          "command": "workcenter.moveUp",
          "when": "view == workcenter.queue",
          "group": "3_reorder"
        },
        {
          "command": "workcenter.moveDown",
          "when": "view == workcenter.queue",
          "group": "3_reorder"
        },
        {
          "command": "workcenter.openInBrowser",
          "when": "viewItem =~ /hasUrl/",
          "group": "2_links"
        },
        {
          "command": "workcenter.runAction",
          "when": "view == workcenter.queue || view == workcenter.focus",
          "group": "0_actions"
        },
        {
          "command": "workcenter.acceptFromInbox",
          "when": "view == workcenter.inbox && viewItem =~ /inboxItem/",
          "group": "inline"
        },
        {
          "command": "workcenter.dismissFromInbox",
          "when": "view == workcenter.inbox && viewItem =~ /inboxItem/",
          "group": "inline"
        },
        {
          "command": "workcenter.dismissFromInbox",
          "when": "view == workcenter.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "workcenter.acceptFromSources",
          "when": "view == workcenter.sources && viewItem =~ /sourceItem/",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@workcenter/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
