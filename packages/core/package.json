    "menus": {
      "view/title": [
        {
          "command": "devdocket.createItem",
          "when": "view == devdocket.queue",
          "group": "navigation"
        },
        {
          "command": "devdocket.createItemFromUrl",
          "when": "view == devdocket.queue",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchInboxToTree",
          "when": "view == devdocket.inbox && devdocket.inboxLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchInboxToFlat",
          "when": "view == devdocket.inbox && devdocket.inboxLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchQueueToTree",
          "when": "view == devdocket.queue && devdocket.queueLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchQueueToFlat",
          "when": "view == devdocket.queue && devdocket.queueLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchFocusToTree",
          "when": "view == devdocket.focus && devdocket.focusLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchFocusToFlat",
          "when": "view == devdocket.focus && devdocket.focusLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchHistoryToTree",
          "when": "view == devdocket.history && devdocket.historyLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchHistoryToFlat",
          "when": "view == devdocket.history && devdocket.historyLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.clearHistory",
          "when": "view == devdocket.history",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchSourcesToTree",
          "when": "view == devdocket.sources && devdocket.sourcesLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchSourcesToFlat",
          "when": "view == devdocket.sources && devdocket.sourcesLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchWatchesToTree",
          "when": "view == devdocket.watches && devdocket.watchesLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchWatchesToFlat",
          "when": "view == devdocket.watches && devdocket.watchesLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.refresh",
          "when": "view == devdocket.inbox || view == devdocket.sources",
          "group": "navigation"
        },
        {
          "command": "devdocket.watchRun",
          "when": "view == devdocket.watches",
          "group": "navigation"
        },
        {
          "command": "devdocket.dismissAllCompletedWatches",
          "when": "view == devdocket.watches",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "devdocket.switchInboxToTree",
          "when": "devdocket.inboxLayout == flat"
        },
        {
          "command": "devdocket.switchInboxToFlat",
          "when": "devdocket.inboxLayout == tree"
