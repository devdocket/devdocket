{
  "name": "devdocket",
  "displayName": "DevDocket",
  "description": "A central hub for managing work across pull requests, issues, investigations, and follow-ups.",
  "version": "0.1.0",
  "publisher": "mthalman",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:devdocket.inbox",
    "onView:devdocket.queue",
    "onView:devdocket.focus",
    "onView:devdocket.sources",
    "onView:devdocket.history",
    "onCommand:devdocket.refresh",
    "onCommand:devdocket.dismissFromSources",
    "onCommand:devdocket.deleteItem"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "DevDocket",
      "properties": {
        "devdocket.logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "description": "Log level for DevDocket output channel"
        },
        "devdocket.showInboxNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when new items arrive in the Inbox"
        },
        "devdocket.viewLayout": {
          "type": "object",
          "default": {},
          "description": "Per-view layout mode. Keys are view names (inbox, queue, focus, history, sources) and values are 'flat' or 'tree'.",
          "properties": {
            "inbox": { "type": "string", "enum": ["flat", "tree"], "default": "tree" },
            "queue": { "type": "string", "enum": ["flat", "tree"], "default": "flat" },
            "focus": { "type": "string", "enum": ["flat", "tree"], "default": "flat" },
            "history": { "type": "string", "enum": ["flat", "tree"], "default": "flat" },
            "sources": { "type": "string", "enum": ["flat", "tree"], "default": "tree" }
          },
          "additionalProperties": false
        },
        "devdocket.historyClearDays": {
          "type": "integer",
          "default": 30,
          "minimum": 1,
          "description": "Age threshold in days for the Clear Old History command. Items older than this are removed."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devdocket",
          "title": "DevDocket",
          "icon": "resources/devdocket.svg"
        }
      ]
    },
    "views": {
      "devdocket": [
        {
          "id": "devdocket.inbox",
          "name": "Inbox"
        },
        {
          "id": "devdocket.queue",
          "name": "Queue"
        },
        {
          "id": "devdocket.focus",
          "name": "Focus"
        },
        {
          "id": "devdocket.history",
          "name": "History"
        },
        {
          "id": "devdocket.sources",
          "name": "Sources"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "devdocket.inbox",
        "contents": "No new items.\nProviders will discover items automatically."
      },
      {
        "view": "devdocket.queue",
        "contents": "No items in your queue.\nAccept items from Inbox or create one manually.\n[Create Work Item](command:devdocket.createItem)"
      },
      {
        "view": "devdocket.focus",
        "contents": "No active work.\nMove items from Queue to start working on them."
      },
      {
        "view": "devdocket.history",
        "contents": "Completed and archived items will appear here."
      },
      {
        "view": "devdocket.sources",
        "contents": "Discovered items from all providers will appear here."
      }
    ],
    "commands": [
      {
        "command": "devdocket.createItem",
        "title": "Create Work Item",
        "category": "DevDocket",
        "icon": "$(add)"
      },
      {
        "command": "devdocket.acceptToFocus",
        "title": "Move to Focus",
        "category": "DevDocket",
        "icon": "$(arrow-right)"
      },
      {
        "command": "devdocket.archiveItem",
        "title": "Archive",
        "category": "DevDocket",
        "icon": "$(archive)"
      },
      {
        "command": "devdocket.completeItem",
        "title": "Complete",
        "category": "DevDocket",
        "icon": "$(check)"
      },
      {
        "command": "devdocket.pauseItem",
        "title": "Pause",
        "category": "DevDocket",
        "icon": "$(debug-pause)"
      },
      {
        "command": "devdocket.resumeItem",
        "title": "Resume",
        "category": "DevDocket",
        "icon": "$(debug-continue)"
      },
      {
        "command": "devdocket.editItem",
        "title": "Edit Work Item",
        "category": "DevDocket",
        "icon": "$(edit)"
      },
      {
        "command": "devdocket.openInBrowser",
        "title": "Open in Browser",
        "category": "DevDocket",
        "icon": "$(link-external)"
      },
      {
        "command": "devdocket.runAction",
        "title": "Run Action…",
        "category": "DevDocket",
        "icon": "$(play)"
      },
      {
        "command": "devdocket.moveUp",
        "title": "Move Up",
        "category": "DevDocket",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devdocket.moveDown",
        "title": "Move Down",
        "category": "DevDocket",
        "icon": "$(arrow-down)"
      },
      {
        "command": "devdocket.focusMoveUp",
        "title": "Move Up",
        "category": "DevDocket",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devdocket.focusMoveDown",
        "title": "Move Down",
        "category": "DevDocket",
        "icon": "$(arrow-down)"
      },
      {
        "command": "devdocket.acceptFromInbox",
        "title": "Accept to Queue",
        "category": "DevDocket",
        "icon": "$(arrow-right)"
      },
      {
        "command": "devdocket.acceptToFocusFromInbox",
        "title": "Accept to Focus",
        "category": "DevDocket",
        "icon": "$(rocket)"
      },
      {
        "command": "devdocket.dismissFromInbox",
        "title": "Dismiss",
        "category": "DevDocket",
        "icon": "$(close)"
      },
      {
        "command": "devdocket.acceptFromSources",
        "title": "Accept to Queue",
        "category": "DevDocket",
        "icon": "$(arrow-right)"
      },
      {
        "command": "devdocket.switchInboxToTree",
        "title": "Switch Inbox to Tree Layout",
        "category": "DevDocket",
        "icon": "$(list-tree)"
      },
      {
        "command": "devdocket.switchInboxToFlat",
        "title": "Switch Inbox to Flat Layout",
        "category": "DevDocket",
        "icon": "$(list-flat)"
      },
      {
        "command": "devdocket.switchQueueToTree",
        "title": "Switch Queue to Tree Layout",
        "category": "DevDocket",
        "icon": "$(list-tree)"
      },
      {
        "command": "devdocket.switchQueueToFlat",
        "title": "Switch Queue to Flat Layout",
        "category": "DevDocket",
        "icon": "$(list-flat)"
      },
      {
        "command": "devdocket.switchFocusToTree",
        "title": "Switch Focus to Tree Layout",
        "category": "DevDocket",
        "icon": "$(list-tree)"
      },
      {
        "command": "devdocket.switchFocusToFlat",
        "title": "Switch Focus to Flat Layout",
        "category": "DevDocket",
        "icon": "$(list-flat)"
      },
      {
        "command": "devdocket.switchHistoryToTree",
        "title": "Switch History to Tree Layout",
        "category": "DevDocket",
        "icon": "$(list-tree)"
      },
      {
        "command": "devdocket.switchHistoryToFlat",
        "title": "Switch History to Flat Layout",
        "category": "DevDocket",
        "icon": "$(list-flat)"
      },
      {
        "command": "devdocket.switchSourcesToTree",
        "title": "Switch Sources to Tree Layout",
        "category": "DevDocket",
        "icon": "$(list-tree)"
      },
      {
        "command": "devdocket.switchSourcesToFlat",
        "title": "Switch Sources to Flat Layout",
        "category": "DevDocket",
        "icon": "$(list-flat)"
      },
      {
        "command": "devdocket.toggleInboxLayout",
        "title": "Toggle Inbox Layout",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.toggleQueueLayout",
        "title": "Toggle Queue Layout",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.toggleFocusLayout",
        "title": "Toggle Focus Layout",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.toggleHistoryLayout",
        "title": "Toggle History Layout",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.toggleSourcesLayout",
        "title": "Toggle Sources Layout",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.dismissFromSources",
        "title": "Dismiss",
        "category": "DevDocket",
        "icon": "$(close)"
      },
      {
        "command": "devdocket.deleteItem",
        "title": "Delete",
        "category": "DevDocket",
        "icon": "$(trash)"
      },
      {
        "command": "devdocket.clearHistory",
        "title": "Clear Old History",
        "category": "DevDocket",
        "icon": "$(clear-all)"
      },
      {
        "command": "devdocket.moveToQueue",
        "title": "Move to Queue",
        "category": "DevDocket",
        "icon": "$(arrow-left)"
      },
      {
        "command": "devdocket.refresh",
        "title": "Refresh",
        "category": "DevDocket",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devdocket.createItem",
          "when": "view == devdocket.queue",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchInboxToTree",
          "when": "view == devdocket.inbox && devdocket.inboxLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchInboxToFlat",
          "when": "view == devdocket.inbox && devdocket.inboxLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchQueueToTree",
          "when": "view == devdocket.queue && devdocket.queueLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchQueueToFlat",
          "when": "view == devdocket.queue && devdocket.queueLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchFocusToTree",
          "when": "view == devdocket.focus && devdocket.focusLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchFocusToFlat",
          "when": "view == devdocket.focus && devdocket.focusLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchHistoryToTree",
          "when": "view == devdocket.history && devdocket.historyLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchHistoryToFlat",
          "when": "view == devdocket.history && devdocket.historyLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.clearHistory",
          "when": "view == devdocket.history",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchSourcesToTree",
          "when": "view == devdocket.sources && devdocket.sourcesLayout == flat",
          "group": "navigation"
        },
        {
          "command": "devdocket.switchSourcesToFlat",
          "when": "view == devdocket.sources && devdocket.sourcesLayout == tree",
          "group": "navigation"
        },
        {
          "command": "devdocket.refresh",
          "when": "view == devdocket.inbox || view == devdocket.sources",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "devdocket.switchInboxToTree",
          "when": "devdocket.inboxLayout == flat"
        },
        {
          "command": "devdocket.switchInboxToFlat",
          "when": "devdocket.inboxLayout == tree"
        },
        {
          "command": "devdocket.switchQueueToTree",
          "when": "devdocket.queueLayout == flat"
        },
        {
          "command": "devdocket.switchQueueToFlat",
          "when": "devdocket.queueLayout == tree"
        },
        {
          "command": "devdocket.switchFocusToTree",
          "when": "devdocket.focusLayout == flat"
        },
        {
          "command": "devdocket.switchFocusToFlat",
          "when": "devdocket.focusLayout == tree"
        },
        {
          "command": "devdocket.switchHistoryToTree",
          "when": "devdocket.historyLayout == flat"
        },
        {
          "command": "devdocket.switchHistoryToFlat",
          "when": "devdocket.historyLayout == tree"
        },
        {
          "command": "devdocket.switchSourcesToTree",
          "when": "devdocket.sourcesLayout == flat"
        },
        {
          "command": "devdocket.switchSourcesToFlat",
          "when": "devdocket.sourcesLayout == tree"
        },
        {
          "command": "devdocket.toggleInboxLayout",
          "when": "false"
        },
        {
          "command": "devdocket.toggleQueueLayout",
          "when": "false"
        },
        {
          "command": "devdocket.toggleFocusLayout",
          "when": "false"
        },
        {
          "command": "devdocket.toggleHistoryLayout",
          "when": "false"
        },
        {
          "command": "devdocket.toggleSourcesLayout",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "devdocket.acceptToFocus",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.archiveItem",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.deleteItem",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.completeItem",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/",
          "group": "inline"
        },
        {
          "command": "devdocket.archiveItem",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.pauseItem",
          "when": "view == devdocket.focus && viewItem =~ /^active/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.resumeItem",
          "when": "view == devdocket.focus && viewItem =~ /^paused/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.moveToQueue",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.moveUp",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/ && !listMultiSelection",
          "group": "3_reorder@1"
        },
        {
          "command": "devdocket.moveDown",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/ && !listMultiSelection",
          "group": "3_reorder@2"
        },
        {
          "command": "devdocket.focusMoveUp",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/ && !listMultiSelection",
          "group": "3_reorder@1"
        },
        {
          "command": "devdocket.focusMoveDown",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/ && !listMultiSelection",
          "group": "3_reorder@2"
        },
        {
          "command": "devdocket.openInBrowser",
          "when": "viewItem =~ /hasUrl/ && !listMultiSelection",
          "group": "2_links"
        },
        {
          "command": "devdocket.runAction",
          "when": "((view == devdocket.queue && viewItem =~ /^queueItem/) || (view == devdocket.focus && viewItem =~ /^(active|paused)/)) && !listMultiSelection",
          "group": "0_actions"
        },
        {
          "command": "devdocket.acceptFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.acceptFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.dismissFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.dismissFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.acceptToFocusFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.acceptFromSources",
          "when": "view == devdocket.sources && viewItem =~ /sourceItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.dismissFromSources",
          "when": "view == devdocket.sources && viewItem =~ /sourceItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.dismissFromSources",
          "when": "view == devdocket.sources && viewItem =~ /sourceItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.archiveItem",
          "when": "view == devdocket.history && viewItem =~ /historyItem\\.done/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.deleteItem",
          "when": "view == devdocket.history && viewItem =~ /^historyItem/",
          "group": "1_actions"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devdocket.createItem",
        "key": "ctrl+alt+d n",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.completeItem",
        "key": "ctrl+alt+d d",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.pauseItem",
        "key": "ctrl+alt+d p",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.resumeItem",
        "key": "ctrl+alt+d u",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.acceptToFocus",
        "key": "ctrl+alt+d f",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.moveToQueue",
        "key": "ctrl+alt+d q",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.refresh",
        "key": "ctrl+alt+d r",
        "when": "focusedView =~ /devdocket/"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@devdocket/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
