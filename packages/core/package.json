{
  "name": "devdocket",
  "displayName": "DevDocket",
  "description": "A central hub for managing work across pull requests, issues, investigations, and follow-ups.",
  "version": "0.1.1",
  "publisher": "devdocket",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "work items",
    "tasks",
    "todo",
    "github",
    "azure devops",
    "pull requests",
    "issues",
    "productivity",
    "hub",
    "inbox"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/devdocket/devdocket.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/devdocket/devdocket/issues"
  },
  "homepage": "https://github.com/devdocket/devdocket#readme",
  "galleryBanner": {
    "color": "#1F2937",
    "theme": "dark"
  },
  "preview": true,
  "activationEvents": [
    "onView:devdocket.main",
    "onWebviewPanel:devdocket.editItem",
    "onWebviewPanel:devdocket.previewItem",
    "onWebviewPanel:devdocket.watchPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "icons": {
      "devdocket-logo": {
        "description": "DevDocket logo",
        "default": {
          "fontPath": "./resources/devdocket-icons.woff",
          "fontCharacter": "\\E001"
        }
      }
    },
    "walkthroughs": [
      {
        "id": "devdocket.gettingStarted",
        "title": "Get Started with DevDocket",
        "description": "Learn how to manage your work items across the Incoming, Ready to Start, In Progress, and Done tiers",
        "steps": [
          {
            "id": "createFirstItem",
            "title": "Create Your First Work Item",
            "description": "Start by creating a manual work item to track your work.",
            "media": {
              "markdown": "media/walkthroughs/create-item.md"
            },
            "completionEvents": [
              "onCommand:devdocket.createItem"
            ]
          },
          {
            "id": "understandWorkflow",
            "title": "Understand the Workflow",
            "description": "Learn how items flow through Incoming → Ready to Start → In Progress → Paused → Done.",
            "media": {
              "markdown": "media/walkthroughs/workflow.md"
            }
          },
          {
            "id": "connectProvider",
            "title": "Connect a Provider",
            "description": "Automatically discover work from GitHub, Azure DevOps, and more.",
            "media": {
              "markdown": "media/walkthroughs/providers.md"
            },
            "completionEvents": [
              "extensionInstalled:devdocket.devdocket-github",
              "extensionInstalled:devdocket.devdocket-ado"
            ]
          },
          {
            "id": "focusOnWork",
            "title": "Start In Progress Work",
            "description": "Move items into the In Progress tier and complete them when done.",
            "media": {
              "markdown": "media/walkthroughs/focus.md"
            },
            "completionEvents": [
              "onCommand:devdocket.acceptToFocus",
              "onCommand:devdocket.acceptToFocusFromInbox",
              "onCommand:devdocket.completeItem"
            ]
          },
          {
            "id": "monitorPipelines",
            "title": "Watch CI Pipelines and PRs",
            "description": "Monitor GitHub Actions and Azure DevOps Pipelines runs without leaving VS Code.",
            "media": {
              "markdown": "media/walkthroughs/watches.md"
            },
            "completionEvents": [
              "onCommand:devdocket.watchUrl",
              "onCommand:devdocket.watchPRFromItem"
            ]
          }
        ]
      }
    ],
    "configuration": [
      {
        "title": "DevDocket",
        "properties": {
          "devDocket.showInboxNotifications": {
            "type": "boolean",
            "default": true,
            "description": "Show a notification when new items arrive in the Inbox"
          },
          "devDocket.autoCompleteOnClose": {
            "type": "boolean",
            "default": true,
            "description": "Automatically mark work items as Done when their linked issue or PR is closed or merged externally"
          },
          "devDocket.historyClearDays": {
            "type": "integer",
            "default": 30,
            "minimum": 1,
            "description": "Age threshold in days for the Clear Old History command. Items older than this are removed."
          },
          "devDocket.watches.pollingIntervalSeconds": {
            "type": "number",
            "default": 60,
            "minimum": 15,
            "description": "Polling interval in seconds for pipeline watches (minimum 15 seconds)"
          },
          "devDocket.watches.notifyOnJobFailure": {
            "type": "boolean",
            "default": true,
            "description": "Show a notification when an individual job fails while the pipeline run is still in progress"
          },
          "devDocket.watches.autoWatchAuthoredPRs": {
            "type": "boolean",
            "default": true,
            "description": "Automatically watch authored pull requests when a provider refresh discovers them"
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devdocket",
          "title": "DevDocket",
          "icon": "resources/devdocket.svg"
        }
      ]
    },
    "views": {
      "devdocket": [
        {
          "type": "webview",
          "id": "devdocket.main",
          "name": "DevDocket"
        }
      ]
    },
    "commands": [
      {
        "command": "devdocket.createItem",
        "title": "Create Work Item",
        "category": "DevDocket",
        "icon": "$(add)"
      },
      {
        "command": "devdocket.createItemFromUrl",
        "title": "Create Item from URL",
        "category": "DevDocket",
        "icon": "$(link)"
      },
      {
        "command": "devdocket.acceptToFocus",
        "title": "Move to Focus",
        "category": "DevDocket",
        "icon": "$(arrow-right)"
      },
      {
        "command": "devdocket.archiveItem",
        "title": "Archive",
        "category": "DevDocket",
        "icon": "$(archive)"
      },
      {
        "command": "devdocket.completeItem",
        "title": "Complete",
        "category": "DevDocket",
        "icon": "$(check)"
      },
      {
        "command": "devdocket.pauseItem",
        "title": "Pause",
        "category": "DevDocket",
        "icon": "$(debug-pause)"
      },
      {
        "command": "devdocket.resumeItem",
        "title": "Resume",
        "category": "DevDocket",
        "icon": "$(debug-continue)"
      },
      {
        "command": "devdocket.editItem",
        "title": "Edit Work Item",
        "category": "DevDocket",
        "icon": "$(edit)"
      },
      {
        "command": "devdocket.openInBrowser",
        "title": "Open in Browser",
        "category": "DevDocket",
        "icon": "$(link-external)"
      },
      {
        "command": "devdocket.copyUrl",
        "title": "Copy URL",
        "category": "DevDocket",
        "icon": "$(copy)"
      },
      {
        "command": "devdocket.runAction",
        "title": "Run Action…",
        "category": "DevDocket",
        "icon": "$(play)"
      },
      {
        "command": "devdocket.moveUp",
        "title": "Move Up",
        "category": "DevDocket",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devdocket.moveDown",
        "title": "Move Down",
        "category": "DevDocket",
        "icon": "$(arrow-down)"
      },
      {
        "command": "devdocket.moveToTop",
        "title": "Move to Top",
        "category": "DevDocket",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devdocket.moveToBottom",
        "title": "Move to Bottom",
        "category": "DevDocket",
        "icon": "$(arrow-down)"
      },
      {
        "command": "devdocket.focusMoveUp",
        "title": "Move Up",
        "category": "DevDocket",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devdocket.focusMoveDown",
        "title": "Move Down",
        "category": "DevDocket",
        "icon": "$(arrow-down)"
      },
      {
        "command": "devdocket.focusMoveToTop",
        "title": "Move to Top",
        "category": "DevDocket",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devdocket.focusMoveToBottom",
        "title": "Move to Bottom",
        "category": "DevDocket",
        "icon": "$(arrow-down)"
      },
      {
        "command": "devdocket.acceptFromInbox",
        "title": "Accept to Queue",
        "category": "DevDocket",
        "icon": "$(arrow-right)"
      },
      {
        "command": "devdocket.acceptToFocusFromInbox",
        "title": "Accept to Focus",
        "category": "DevDocket",
        "icon": "$(rocket)"
      },
      {
        "command": "devdocket.acceptAllFromInbox",
        "title": "Accept All to Queue",
        "category": "DevDocket",
        "icon": "$(check)"
      },
      {
        "command": "devdocket.acceptAllToFocusFromInbox",
        "title": "Accept All to Focus",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.dismissFromInbox",
        "title": "Dismiss",
        "category": "DevDocket",
        "icon": "$(close)"
      },
      {
        "command": "devdocket.dismissAllFromInbox",
        "title": "Dismiss All",
        "category": "DevDocket",
        "icon": "$(close)"
      },
      {
        "command": "devdocket.acceptFromSources",
        "title": "Accept to Queue",
        "category": "DevDocket",
        "icon": "$(arrow-right)"
      },
      {
        "command": "devdocket.dismissFromSources",
        "title": "Dismiss",
        "category": "DevDocket",
        "icon": "$(close)"
      },
      {
        "command": "devdocket.deleteItem",
        "title": "Delete",
        "category": "DevDocket",
        "icon": "$(trash)"
      },
      {
        "command": "devdocket.clearHistory",
        "title": "Clear Old History",
        "category": "DevDocket",
        "icon": "$(clear-all)"
      },
      {
        "command": "devdocket.addActivity",
        "title": "Add Activity Log Entry",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.moveToQueue",
        "title": "Move to Queue",
        "category": "DevDocket",
        "icon": "$(arrow-left)"
      },
      {
        "command": "devdocket.refresh",
        "title": "Refresh",
        "category": "DevDocket",
        "icon": "$(refresh)"
      },
      {
        "command": "devdocket.watchUrl",
        "title": "Watch URL…",
        "category": "DevDocket",
        "icon": "$(add)"
      },
      {
        "command": "devdocket.watchPRFromItem",
        "title": "Watch CI",
        "category": "DevDocket",
        "icon": "$(eye)"
      },
      {
        "command": "devdocket.dismissWatch",
        "title": "Dismiss Watch",
        "category": "DevDocket",
        "icon": "$(close)"
      },
      {
        "command": "devdocket.dismissAllCompletedWatches",
        "title": "Dismiss All Completed",
        "category": "DevDocket",
        "icon": "$(clear-all)"
      },
      {
        "command": "devdocket.showProviderHealthQuickPick",
        "title": "Show Provider Health",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.openWatchUrl",
        "title": "Open in Browser",
        "category": "DevDocket",
        "icon": "$(link-external)"
      },
      {
        "command": "devdocket.showWatchesQuickPick",
        "title": "Show Watches",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.openWalkthrough",
        "title": "Open Walkthrough",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.browseProviderExtensions",
        "title": "Browse Provider Extensions",
        "category": "DevDocket"
      },
      {
        "command": "devdocket.toggleSearch",
        "title": "Toggle Search",
        "category": "DevDocket",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devdocket.toggleSearch",
          "when": "view == devdocket.main",
          "group": "navigation@1"
        },
        {
          "command": "devdocket.createItem",
          "when": "view == devdocket.main",
          "group": "navigation@2"
        },
        {
          "command": "devdocket.createItemFromUrl",
          "when": "view == devdocket.main",
          "group": "navigation@3"
        },
        {
          "command": "devdocket.refresh",
          "when": "view == devdocket.main",
          "group": "navigation@4"
        }
      ],
      "commandPalette": [
        {
          "command": "devdocket.addActivity",
          "when": "false"
        },
        {
          "command": "devdocket.watchPRFromItem",
          "when": "false"
        },
        {
          "command": "devdocket.copyUrl",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devdocket.toggleSearch",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "focusedView == devdocket.main"
      },
      {
        "command": "devdocket.createItem",
        "key": "ctrl+alt+d n",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.completeItem",
        "key": "ctrl+alt+d d",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.pauseItem",
        "key": "ctrl+alt+d p",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.resumeItem",
        "key": "ctrl+alt+d u",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.acceptToFocus",
        "key": "ctrl+alt+d f",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.moveToQueue",
        "key": "ctrl+alt+d q",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.refresh",
        "key": "ctrl+alt+d r",
        "when": "focusedView =~ /devdocket/"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild src/webview/sidebar/index.tsx --bundle --outfile=webview-dist/sidebar.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact --sourcemap && esbuild src/webview/editor/index.tsx --bundle --outfile=webview-dist/editor.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact --sourcemap && esbuild src/webview/watchPanel/index.tsx --bundle --outfile=webview-dist/watchPanel.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact --sourcemap",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap && esbuild src/webview/sidebar/index.tsx --bundle --outfile=webview-dist/sidebar.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact --minify --sourcemap && esbuild src/webview/editor/index.tsx --bundle --outfile=webview-dist/editor.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact --minify --sourcemap && esbuild src/webview/watchPanel/index.tsx --bundle --outfile=webview-dist/watchPanel.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact --minify --sourcemap",
    "build:icons": "node scripts/build-icons.mjs",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@devdocket/shared": "*",
    "@vscode/codicons": "^0.0.45",
    "marked": "^18.0.2",
    "preact": "^10.29.1",
    "sanitize-html": "^2.17.3",
    "timeago.js": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/vscode": "^1.92.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "fantasticon": "^3.0.0",
    "jsdom": "^24.1.3",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
