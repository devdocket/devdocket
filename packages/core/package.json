        {
          "command": "devdocket.watchPRFromItem",
          "when": "false"
        },
        {
          "command": "devdocket.copyUrl",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "devdocket.acceptToFocus",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.archiveItem",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.deleteItem",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.completeItem",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/",
          "group": "inline"
        },
        {
          "command": "devdocket.archiveItem",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.pauseItem",
          "when": "view == devdocket.focus && viewItem =~ /^active/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.resumeItem",
          "when": "view == devdocket.focus && viewItem =~ /^paused/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.moveToQueue",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.moveToTop",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/ && !listMultiSelection",
          "group": "3_reorder@0"
        },
        {
          "command": "devdocket.moveUp",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/ && !listMultiSelection",
          "group": "3_reorder@1"
        },
        {
          "command": "devdocket.moveDown",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/ && !listMultiSelection",
          "group": "3_reorder@2"
        },
        {
          "command": "devdocket.moveToBottom",
          "when": "view == devdocket.queue && viewItem =~ /^queueItem/ && !listMultiSelection",
          "group": "3_reorder@3"
        },
        {
          "command": "devdocket.focusMoveToTop",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/ && !listMultiSelection",
          "group": "3_reorder@0"
        },
        {
          "command": "devdocket.focusMoveUp",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/ && !listMultiSelection",
          "group": "3_reorder@1"
        },
        {
          "command": "devdocket.focusMoveDown",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/ && !listMultiSelection",
          "group": "3_reorder@2"
        },
        {
          "command": "devdocket.focusMoveToBottom",
          "when": "view == devdocket.focus && viewItem =~ /^(active|paused)/ && !listMultiSelection",
          "group": "3_reorder@3"
        },
        {
          "command": "devdocket.openInBrowser",
          "when": "viewItem =~ /hasUrl/ && !listMultiSelection",
          "group": "2_links@0"
        },
        {
          "command": "devdocket.copyUrl",
          "when": "viewItem =~ /hasUrl/ && !listMultiSelection",
          "group": "2_links@1"
        },
        {
          "command": "devdocket.watchPRFromItem",
          "when": "view == devdocket.focus && viewItem =~ /watchable/ && !listMultiSelection",
          "group": "2_links@2"
        },
        {
          "command": "devdocket.watchPRFromItem",
          "when": "view == devdocket.queue && viewItem =~ /watchable/ && !listMultiSelection",
          "group": "2_links@2"
        },
        {
          "command": "devdocket.runAction",
          "when": "((view == devdocket.queue && viewItem =~ /^queueItem/) || (view == devdocket.focus && viewItem =~ /^(active|paused)/)) && viewItem =~ /\\.hasActions/ && !listMultiSelection",
          "group": "0_actions"
        },
        {
          "command": "devdocket.acceptFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.acceptFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.dismissFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.dismissFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.acceptToFocusFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.acceptAllFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxProvider|inboxGroup/",
          "group": "inline"
        },
        {
          "command": "devdocket.dismissAllFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxProvider|inboxGroup/",
          "group": "inline"
        },
        {
          "command": "devdocket.acceptAllFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxProvider|inboxGroup/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.acceptAllToFocusFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxProvider|inboxGroup/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.dismissAllFromInbox",
          "when": "view == devdocket.inbox && viewItem =~ /inboxProvider|inboxGroup/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.acceptFromSources",
          "when": "view == devdocket.sources && viewItem =~ /sourceItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.dismissFromSources",
          "when": "view == devdocket.sources && viewItem =~ /sourceItem/",
          "group": "inline"
        },
        {
          "command": "devdocket.dismissFromSources",
          "when": "view == devdocket.sources && viewItem =~ /sourceItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.moveToQueue",
          "when": "view == devdocket.history && viewItem =~ /^historyItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.archiveItem",
          "when": "view == devdocket.history && viewItem =~ /historyItem\\.done/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.deleteItem",
          "when": "view == devdocket.history && viewItem =~ /^historyItem/",
          "group": "1_actions"
        },
        {
          "command": "devdocket.dismissWatch",
          "when": "view == devdocket.watches && viewItem =~ /^watchedRun|^watchedPR/",
          "group": "inline"
        },
        {
          "command": "devdocket.openWatchUrl",
          "when": "view == devdocket.watches && viewItem =~ /^watchedRun|^watchedPR/",
          "group": "1_actions"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devdocket.createItem",
        "key": "ctrl+alt+d n",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.completeItem",
        "key": "ctrl+alt+d d",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.pauseItem",
        "key": "ctrl+alt+d p",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.resumeItem",
        "key": "ctrl+alt+d u",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.acceptToFocus",
        "key": "ctrl+alt+d f",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.moveToQueue",
        "key": "ctrl+alt+d q",
        "when": "focusedView =~ /devdocket/"
      },
      {
        "command": "devdocket.refresh",
        "key": "ctrl+alt+d r",
        "when": "focusedView =~ /devdocket/"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild src/webview/sidebar/index.tsx --bundle --outfile=webview-dist/sidebar.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact --sourcemap",
    "build:prod": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap && esbuild src/webview/sidebar/index.tsx --bundle --outfile=webview-dist/sidebar.js --format=esm --platform=browser --jsx=automatic --jsx-import-source=preact --minify --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@devdocket/shared": "*",
    "marked": "^18.0.2",
    "preact": "^10.29.1",
    "sanitize-html": "^2.17.3",
    "timeago.js": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
