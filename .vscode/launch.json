{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Core Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/packages/core"],
      "outFiles": ["${workspaceFolder}/packages/core/dist/**/*.js"],
      "preLaunchTask": "npm: watch - core"
    }
  ]
}
