{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extensions",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/core",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/github",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/ado",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/ai-reviewer"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/core/dist/**/*.js",
        "${workspaceFolder}/packages/github/dist/**/*.js",
        "${workspaceFolder}/packages/ado/dist/**/*.js",
        "${workspaceFolder}/packages/ai-reviewer/dist/**/*.js"
      ],
      "preLaunchTask": "build all"
    }
  ]
}
